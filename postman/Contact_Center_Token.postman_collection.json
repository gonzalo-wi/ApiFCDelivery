{
	"info": {
		"_postman_id": "cc123456-7890-abcd-ef12-345678901234",
		"name": "Contact Center - Token API",
		"description": "Endpoint público para que el contact center obtenga el token de un delivery sin autenticación",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Obtener Token por Fecha y Cuenta",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has required fields\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData).to.have.property('fecha_accion');",
							"    pm.expect(jsonData).to.have.property('nro_cta');",
							"    pm.expect(jsonData).to.have.property('token');",
							"});",
							"",
							"pm.test(\"Token is not empty\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.token).to.not.be.empty;",
							"});",
							"",
							"// Save token as environment variable for use in other requests",
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    pm.environment.set(\"delivery_token\", jsonData.token);",
							"    console.log(\"Token guardado: \" + jsonData.token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/deliveries/contact-center/token?fecha_accion={{fecha_accion}}&nro_cta={{nro_cta}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"deliveries",
						"contact-center",
						"token"
					],
					"query": [
						{
							"key": "fecha_accion",
							"value": "{{fecha_accion}}",
							"description": "Fecha de acción en formato YYYY-MM-DD"
						},
						{
							"key": "nro_cta",
							"value": "{{nro_cta}}",
							"description": "Número de cuenta del cliente"
						}
					]
				},
				"description": "Endpoint público (sin autenticación) para obtener el token de un delivery.\n\n**Parámetros:**\n- `fecha_accion` (obligatorio): Fecha en formato YYYY-MM-DD\n- `nro_cta` (obligatorio): Número de cuenta del cliente\n\n**Respuesta exitosa:**\n```json\n{\n    \"id\": 18,\n    \"fecha_accion\": \"2026-03-21\",\n    \"nro_cta\": \"43534\",\n    \"token\": \"2181\"\n}\n```"
			},
