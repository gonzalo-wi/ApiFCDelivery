		{
			"name": "Buscar múltiples deliveries (con fecha)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is an array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"if (pm.response.json().length > 0) {",
							"    pm.test(\"First item has token\", function () {",
							"        var jsonData = pm.response.json();",
							"        pm.expect(jsonData[0]).to.have.property('token');",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/deliveries/contact-center/token?fecha_accion={{fecha_accion}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"deliveries",
						"contact-center",
						"token"
					],
					"query": [
						{
							"key": "fecha_accion",
							"value": "{{fecha_accion}}",
							"description": "Fecha de acción en formato YYYY-MM-DD"
						}
					]
				},
				"description": "Busca todos los deliveries de una fecha específica (útil para ver qué cuentas tienen delivery ese día)"
			},
